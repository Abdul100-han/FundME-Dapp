# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Primary Sepolia RPC (Alchemy / Infura recommended)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Optional fallback Sepolia RPC if the primary endpoint is unavailable
NEXT_PUBLIC_SEPOLIA_RPC_FALLBACK_URL=https://ethereum-sepolia.publicnode.com
